# AI Tour Operating System — Environment Variables
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=postgresql://tour:tour_secret_2026@localhost:5433/ai_tour_os

# Redis
REDIS_URL=redis://localhost:6380

# Qdrant (Vector DB for AI RAG)
QDRANT_URL=http://localhost:6334

# AI APIs (at least one required)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Zalo Official Account
ZALO_OA_APP_ID=your-zalo-app-id
ZALO_OA_SECRET=your-zalo-app-secret
ZALO_OA_ACCESS_TOKEN=your-zalo-access-token

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change-me-to-a-64-char-random-hex-string

# Admin password (argon2 hash — generate online or via script)
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# Optional: Sentry, Analytics, etc.
SENTRY_DSN=
